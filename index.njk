---
layout: base.njk
---
<section class="intro">
  <p>{{ site.description }}</p>
</section>

<section class="post-list">
  {% for post in collections.post | reverse %}
  <article class="post-list-item">
    <h2><a href="{{ post.url }}">{{ post.data.title }}</a></h2>
    <p class="post-meta">
      <time datetime="{{ post.date | isoDate }}">{{ post.date | readableDate }}</time>
      {% if post.data.category %} · <span class="post-category">{{ post.data.category }}</span>{% endif %}
    </p>
    {% if post.data.summary %}<p class="post-summary">{{ post.data.summary }}</p>{% endif %}
  </article>
  {% endfor %}
</section>
